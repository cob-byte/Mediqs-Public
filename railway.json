{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
      "builder": "NIXPACKS",
      "nixpacksPlan": {
          "providers": ["python"],
          "phases": {
              "setup": {
                  "nixPkgs": ["...", "nodejs"]
              }
          }
      }
    },
    "deploy": {
      "startCommand": "python3 manage.py migrate && python3 manage.py collectstatic --noinput && python3 -m gunicorn Mediqs.wsgi:application --bind 0.0.0.0:$PORT",
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 10
    }
  }
